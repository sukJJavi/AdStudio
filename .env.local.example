# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API — console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Trigger.dev — Project settings > API keys
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=

# Resend — dashboard de Resend > API Keys
RESEND_API_KEY=
# Remitente de los emails transaccionales (aprobación de master, cambios solicitados).
# Requiere un dominio verificado en Resend. Si se deja vacía, el código cae al
# remitente de pruebas onboarding@resend.dev (válido en desarrollo, no en producción).
RESEND_FROM_EMAIL=

# Stripe — Dashboard > Developers > API keys / Webhooks
# Reservado para el módulo de suscripciones (tiers Starter/Studio/Agency, ver
# CLAUDE.md). Todavía no hay código que los use — no existe /api/stripe ni
# checkout; documentadas aquí para cuando se implemente.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# URL pública de la app — Vercel: Project Settings > Domains
# (o http://localhost:3000 en local). Se usa como origen canónico para los
# links de aprobación (/approve/[token]); si se deja vacía, se usa el origen
# de la request entrante.
NEXT_PUBLIC_APP_URL=
